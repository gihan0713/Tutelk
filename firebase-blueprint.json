{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform (student or tutor)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "tutor", "admin"] },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "role", "name", "email", "createdAt"]
    },
    "TutorProfile": {
      "title": "Tutor Profile",
      "description": "Public profile details for a tutor",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "subjects": { "type": "array", "items": { "type": "string" } },
        "locations": { "type": "array", "items": { "type": "string" } },
        "hourlyRate": { "type": "number" },
        "contactNumber": { "type": "string" },
        "gallery": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "subjects", "locations", "hourlyRate", "updatedAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat session between a student and a tutor",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "tutorId": { "type": "string" },
        "studentName": { "type": "string" },
        "tutorName": { "type": "string" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "tutorId", "studentName", "tutorName", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "text", "createdAt"]
    },
    "Request": {
      "title": "Tutoring Request",
      "description": "A request from a student to a tutor",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "tutorId": { "type": "string" },
        "studentName": { "type": "string" },
        "studentEmail": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "tutorId", "studentName", "studentEmail", "message", "status", "createdAt"]
    },
    "Payment": {
      "title": "Payment",
      "description": "A payment slip uploaded by a tutor",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "slipUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "userEmail", "slipUrl", "status", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "bankDetails": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["bankDetails", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/tutors/{tutorId}": {
      "schema": { "$ref": "#/entities/TutorProfile" },
      "description": "Public tutor profiles"
    },
    "/requests/{requestId}": {
      "schema": { "$ref": "#/entities/Request" },
      "description": "Tutoring requests"
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Chat sessions"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages within a chat"
    },
    "/payments/{paymentId}": {
      "schema": { "$ref": "#/entities/Payment" },
      "description": "Payment slips uploaded by tutors"
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "Global application settings"
    }
  }
}
